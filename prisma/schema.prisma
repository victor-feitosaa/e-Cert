generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String?
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  systemRole      SystemRole     @default(USER)

  events    Event[]    @relation("EventCreator")
  subEvents    SubEvent[]    @relation("SubEventCreator")
  eventTeam EventTeam[]
  subEventTeam SubEventTeam[]
  grantedPermissions EventPermission[] @relation("Granter")
  receveidPermissions EventPermission[] @relation("GrantedUser")
  
}

model Event {
  id          String   @id @default(uuid())
  title       String
  description String
  date        DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  location    String?
  isPublic    Boolean  @default(true)

  createdBy String
  creator   User       @relation("EventCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  subEvents SubEvent[]
  eventTeam EventTeam[]
  eventPermissions EventPermission[]
  
}

model SubEvent {
  id          String   @id @default(uuid())
  title       String
  description String
  date        DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy String
  eventId String

  creator  User  @relation("SubEventCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  subEvent SubEventTeam[]

}


//PERMISSIONS

enum SystemRole {
  ADMIN
  MODERATOR
  USER
}

enum EventPermissionType {
  MANAGE_EVENT
  MANAGE_SUBEVENTS
  MANAGE_ATTENDEES
  MANAGE_PERMISSIONS
  VIEW_ANALYTICS
}

enum EventRole {
  ORGANIZER
  MODERATOR
}

model EventPermission {
  id  String  @id @default(uuid())
  userId  String
  eventId String
  role  EventRole @default(MODERATOR)
  permissions EventPermissionType[]
  grantedBy String
  grantedAt DateTime  @default(now())
  expiresAt DateTime?

  user  User  @relation("GrantedUser", fields: [userId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  granter User  @relation("Granter", fields: [grantedBy], references: [id])

  @@unique([userId, eventId])
  @@map("event_permissions")
}


//EQUIPES

model EventTeam {
  id    String  @id @default(uuid())
  name  String 
  job   String
  role  SystemRole?
  
  userId  String
  eventId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
  event Event @relation(fields: [eventId], references: [id])

}

model SubEventTeam {
  id    String  @id @default(uuid())
  name  String 
  job   String
  role  SystemRole?
  
  userId  String
  subEventId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
  subEvent SubEvent @relation(fields: [subEventId], references: [id])

}




