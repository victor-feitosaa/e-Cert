---
import Particles from "../Particles.jsx";
import DotGrid from "../DotGrid";
import { LoginForm } from "../login-form";
import { AuthForm} from "../AuthForm";
---

<section class="dark bg-background min-h-screen w-full px-15 flex items-center justify-center overflow-hidden relative">
    
    <div class="absolute inset-0 w-full h-full z-0" style="height: 100vh;">
        <div class="absolute inset-0 w-full h-full">
            <Particles
                client:load
                particleCount={300}
                particleSpread={8}
                speed={0.05}
                particleColors={["#8b5cf6", "#a78bfa", "#6d28d9"]}
                particleBaseSize={80}
                alphaParticles={true}
                disableRotation={false}
                className="w-full h-full"
            />
        </div>

        <div class="absolute inset-0 w-full h-full">
            <DotGrid
                client:load
                dotSize={3}
                gap={28}
                baseColor="#3d3860"
                activeColor="#7c3aed"
                proximity={0}
                speedTrigger={80}
                shockRadius={0}
                shockStrength={4}
                className="absolute inset-0"
            />
        </div>
    </div>

    <div class="z-10 w-1/2">
        <AuthForm client:load/>
    </div>

</section>