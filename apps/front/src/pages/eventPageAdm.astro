---
import EventAnalytics from "@/components/sections/EventAnalytics.astro"
import Layout from "../layouts/Layout.astro"

export const prerender = false;

const id = Astro.url.searchParams.get("id");
if (!id) return Astro.redirect("/userDashboard");

const cookieHeader = Astro.request.headers.get("cookie") ?? "";

let event = null;
let fetchError = null;

const baseUrl = `${import.meta.env.VITE_API_URL ?? "http://localhost:5001"}`

console.log("BASE URL: ", baseUrl)

try {

  console.log("FAZENDO FETCH DE ", `${baseUrl}/events/${id}`)
  const res = await fetch(`${baseUrl}/events/${id}`, {
    headers: { ...(cookieHeader ? { Cookie: cookieHeader } : {}) },
  });

  if (res.ok) {
    const data = await res.json();
    event = data.data?.event ?? data;
  } else if (res.status === 404) {
    // evento não existe de fato
    return Astro.redirect("/userDashboard");
  } else if (res.status === 403) {
    // não redireciona — deixa o frontend lidar
    fetchError = 403;
  }
} catch (err) {
  console.error("Erro ao buscar evento:", err);
}

// só redireciona se realmente não encontrou (não para 403)
if (!event && fetchError !== 403) {
  return Astro.redirect("/userDashboard");
}
---

<Layout>
  {event ? (
    <EventAnalytics event={event} />
  ) : (
    <div class="min-h-screen flex items-center justify-center">
      <p class="text-red-400">Você não tem permissão para acessar este evento.</p>
    </div>
  )}
</Layout>