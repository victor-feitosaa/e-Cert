---
import Layout from "../layouts/Layout.astro"
import Dashboard from "@/components/Dashboard"
import DotGrid from "@/components/DotGrid"

export const prerender = false;

const cookieHeader = Astro.request.headers.get("cookie") || "";
const baseUrl = "http://localhost:5001"

const res = await fetch(`${baseUrl}/user/`, {
  method: "GET",
  headers: { ...(cookieHeader ? { "Cookie": cookieHeader } : {}) },
});
const userData = res.ok ? await res.json() : null;

const resEvents = await fetch(`${baseUrl}/events/my/events`, {
  method: "GET",
  headers: { ...(cookieHeader ? { "Cookie": cookieHeader } : {}) },
});
const eventsData = resEvents.ok ? await resEvents.json() : null;

// serializa para string
const userDataStr = JSON.stringify(userData);
const eventsDataStr = JSON.stringify(eventsData);
---

<Layout>
  <section class="dark bg-background min-h-screen w-full overflow-hidden relative">
    
    <div class="absolute inset-0 w-full h-full z-0 opacity-40">
      <DotGrid
        client:load
        dotSize={3}
        gap={28}
        baseColor="#3d3860"
        activeColor="#7c3aed"
        proximity={0}
        speedTrigger={80}
        shockRadius={0}
      />
    </div>

    <div class="relative z-10">
      <Dashboard 
        client:load 
        userDataStr={userDataStr} 
        eventsDataStr={eventsDataStr} 
      />
    </div>

  </section>
</Layout>